# 本机库（请按实际修改用户名/密码/库名）
# 本机约定：库名 mcp_agent_db；Redis 使用 Memurai（E:\AI\Memurai，端口 6379）
DATABASE_URL=postgresql+psycopg://postgres:YOUR_PASSWORD@localhost:5432/mcp_agent_db
REDIS_URL=redis://localhost:6379/0

# 火山引擎（方舟）— 按你控制台实际 Endpoint / Key 填写
ARK_API_KEY=
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_MODEL=doubao-seed-1-8-251228
EMBEDDING_MODEL=doubao-embedding-vision-251215
EMBEDDING_DIMENSIONS=1024

# 服务发现（本地）
API_URL=http://localhost:8000
ORCHESTRATOR_URL=http://localhost:8001
KNOWLEDGE_MCP_URL=http://localhost:8101
MEMORY_MCP_URL=http://localhost:8102
BUSINESS_MCP_URL=http://localhost:8103
# api 调 orchestrator：local（同进程，默认/pytest）| http（多进程 :8001）
ORCHESTRATOR_MODE=local

# 鉴权（MVP 可关；预留）
# Chat Console 建议用 dev_header，以便识别入口页的 X-User-Id
AUTH_PROVIDER=none
# AUTH_PROVIDER=dev_header
# JWT_SECRET=

# Chat Console（可选；dev 默认走 Vite 代理 /api → :8000）
# VITE_API_BASE=http://127.0.0.1:8000

# 解析（MVP 仅 md/text）
PARSER_ENABLED=markdown,text

# 开发调试接口
DEBUG_ENDPOINTS=true
